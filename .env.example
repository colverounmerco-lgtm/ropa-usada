# Seguridad
SECRET_KEY=cambia-esto-por-texto-largo-y-aleatorio

# Base de datos (Railway te da esta URL automáticamente)
DATABASE_URL=postgresql://usuario:password@host:5432/dbname

# Admin
ADMIN_EMAIL=tu-email@gmail.com
ADMIN_PASSWORD=tu-password-de-admin

# Tienda
NOMBRE_TIENDA=Marketplace Ecuador
BANCO_NOMBRE=Banco Pichincha
BANCO_CUENTA=2200123456
BANCO_TITULAR=Tu Nombre Completo

# Cloudinary (imágenes en la nube)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# URL pública de la app (para PWA / Play Store)
APP_URL=https://tu-app.railway.app
# TWA (Android / Play Store) - se obtienen al crear el APK en PWABuilder
TWA_PACKAGE=com.tunombre.marketplace
TWA_FINGERPRINT=

# Solo para desarrollo local
DEBUG=false
